"-- Mnemonic: [k]onsequent
vim.keymap.set('n', 'k', 'e', { silent = true })
vim.keymap.set('n', 'K', 'E', { silent = true })

"-- Mnemonic: [j]ump until
vim.keymap.set('n', 'j', 'n', { silent = true })
vim.keymap.set('n', 'J', 'N', { silent = true })

"-- Mnemonic: [l]ose
vim.keymap.set('n', 'l', 'o', { silent = true })
vim.keymap.set('n', 'L', 'O', { silent = true })

"-- Mnemonic: [h]ouse
vim.keymap.set('n', 'h', 'y', { silent = true })
vim.keymap.set('n', 'H', 'Y', { silent = true })
